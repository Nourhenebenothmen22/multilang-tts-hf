APP_NAME=tts-hf
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

HF_MODEL=facebook/mms-tts-fra
HF_TOKEN=
HF_CACHE_DIR=/app/.cache/huggingface

OUTPUT_DIR=/app/data/output
DEFAULT_TEXT=Bonjour, ceci est un test de synthese vocale avec Hugging Face.
DEFAULT_OUTPUT_FILE=sample_output.wav

DEVICE=cpu
PRELOAD_MODEL=true
MAX_TEXT_LENGTH=500